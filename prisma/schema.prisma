generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CLIENT
  ACCOUNTANT
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  firstName String?
  lastName  String?
  imageUrl  String?
  role      UserRole @default(CLIENT)
  onboarded Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts              Account[]
  transactions          Transaction[]
  budgets               Budget[]
  categories            Category[]
  subscriptions         Subscription[]
  ownedOrganizations    Organization[]
  organizationMembers   OrganizationMember[]
  documents             Document[]
  googleDriveConnection GoogleDriveConnection?
  reports               Report[]
  transactionNotes      TransactionNote[]
  sentMessages          Message[]
  transactionFlags      TransactionFlag[]
  marketSales           MarketSale[]
  costEntries           CostEntry[]
  adSpends              AdSpend[]
}

model Organization {
  id         String   @id @default(cuid())
  clerkOrgId String   @unique
  name       String
  ownerId    String
  owner      User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  members  OrganizationMember[]
  messages Message[]

  @@index([ownerId])
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  clerkRole      String
  createdAt      DateTime     @default(now())

  @@unique([organizationId, userId])
  @@index([userId])
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plaidAccountId    String?  @unique
  plaidAccessToken  String?
  plaidItemId       String?
  name              String
  officialName      String?
  type              AccountType
  subtype           String?
  mask              String?
  currentBalance    Decimal  @default(0) @db.Decimal(12, 2)
  availableBalance  Decimal? @db.Decimal(12, 2)
  isoCurrencyCode   String   @default("USD")
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  transactions Transaction[]

  @@index([userId])
}

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT
  INVESTMENT
  LOAN
  OTHER
}

model Transaction {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId           String
  account             Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  plaidTransactionId  String?  @unique
  categoryId          String?
  category            Category? @relation(fields: [categoryId], references: [id])
  amount              Decimal  @db.Decimal(12, 2)
  name                String
  merchantName        String?
  date                DateTime
  pending             Boolean  @default(false)
  isoCurrencyCode     String   @default("USD")
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  transactionNotes TransactionNote[]
  flag             TransactionFlag?

  @@index([userId])
  @@index([accountId])
  @@index([date])
}

model Category {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  icon      String?
  color     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  transactions Transaction[]
  budgets      Budget[]

  @@unique([userId, name])
}

model Budget {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  amount     Decimal  @db.Decimal(12, 2)
  period     BudgetPeriod @default(MONTHLY)
  startDate  DateTime
  endDate    DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
}

enum BudgetPeriod {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

model Subscription {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId    String? @unique
  stripeSubscriptionId String? @unique
  stripePriceId       String?
  plan        SubscriptionPlan @default(FREE)
  status      SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

enum SubscriptionPlan {
  FREE
  STARTER
  PROFESSIONAL
  BUSINESS
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum ParsedStatus {
  PENDING
  PARSING
  PARSED
  FAILED
  SKIPPED
}

enum SyncStatus {
  SYNCED
  PENDING
  ERROR
}

model Document {
  id                String       @id @default(cuid())
  userId            String
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name              String
  size              Int
  mimeType          String
  storagePath       String
  url               String
  parsedStatus      ParsedStatus @default(PENDING)
  parseError        String?
  googleDriveFileId String?      @unique
  syncStatus        SyncStatus?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([userId])
  @@index([googleDriveFileId])
}

enum ReportType {
  MONTHLY_PL
  TAX_DEDUCTIONS
  CASH_FLOW_FORECAST
  BUSINESS_HEALTH_SCORE
}

enum ReportStatus {
  GENERATING
  COMPLETED
  FAILED
}

model Report {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      ReportType
  status    ReportStatus @default(GENERATING)
  title     String
  content   String       @db.Text
  metadata  Json?
  error     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  sharedLinks SharedReportLink[]

  @@index([userId])
  @@index([userId, type])
  @@index([createdAt])
}

// ── Collaboration Models ──

model TransactionNote {
  id            String   @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content       String   @db.Text
  parentId      String?
  parent        TransactionNote?  @relation("NoteThread", fields: [parentId], references: [id])
  replies       TransactionNote[] @relation("NoteThread")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([transactionId])
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content        String       @db.Text
  readBy         Json         @default("[]")
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([senderId])
}

enum TransactionFlagStatus {
  NEEDS_REVIEW
  APPROVED
}

model TransactionFlag {
  id            String                @id @default(cuid())
  transactionId String                @unique
  transaction   Transaction           @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  status        TransactionFlagStatus
  flaggedBy     String
  user          User                  @relation(fields: [flaggedBy], references: [id])
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([flaggedBy])
}

model SharedReportLink {
  id        String    @id @default(cuid())
  reportId  String
  report    Report    @relation(fields: [reportId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
}

// ── Jamaica House Brand Models ──

model MarketSale {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime
  location    String
  product     String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  totalSale   Decimal  @db.Decimal(10, 2)
  saleType    String   @default("RETAIL")
  vendorFee   Decimal? @db.Decimal(10, 2)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([date])
  @@index([location])
}

model CostEntry {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime
  supplier    String
  item        String
  quantity    Decimal  @db.Decimal(10, 2)
  unitCost    Decimal  @db.Decimal(10, 2)
  totalCost   Decimal  @db.Decimal(10, 2)
  category    String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([date])
}

model AdSpend {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime
  platform    String
  campaign    String?
  spend       Decimal  @db.Decimal(10, 2)
  impressions Int?
  clicks      Int?
  conversions Int?
  revenue     Decimal? @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([date])
}

model GoogleDriveConnection {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken   String
  refreshToken  String
  tokenExpiry   DateTime
  folderId      String?
  folderName    String?
  lastSyncAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
